#!/bin/bash
# cteam-doctor [owner/repo] — dependency & wiring check for cteam. Read-only.
#
# Checks (installs NOTHING; interactive setup gets guidance instead):
#   1. CLI dependencies (tmux, gh, claude, node, python3) + gh auth
#   2. Claude Code plugins required by the protocol
#   3. cteam wiring: skills, agents, roles, PATH, CLAUDE.md pointer
#   4. Vault structure
#   5. Optional: lint-hook lib, target repo label scheme
#
# Exit: 0 all required checks pass, 1 otherwise.

SELF="$0"
while [ -L "$SELF" ]; do SELF="$(readlink "$SELF")"; done
CTEAM_HOME="$(cd "$(dirname "$SELF")/.." && pwd)"

TARGET_REPO="${1:-}"
FAIL=0

ok()   { printf ' \033[32m✓\033[0m %s\n' "$1"; }
bad()  { printf ' \033[31m✗\033[0m %s\n' "$1"; FAIL=1; }
warn() { printf ' \033[33m⚠\033[0m %s\n' "$1"; }

SETTINGS="$HOME/.claude/settings.json"

echo "cteam-doctor — $CTEAM_HOME"
echo
echo "── CLI dependencies ─────────────────────────────"
for cmd in git tmux gh claude node python3; do
  if command -v "$cmd" >/dev/null 2>&1; then
    ok "$cmd ($(command -v "$cmd"))"
  else
    bad "$cmd not found"
  fi
done

if command -v gh >/dev/null 2>&1; then
  if gh auth status >/dev/null 2>&1; then
    ok "gh authenticated"
  else
    bad "gh not authenticated — run: gh auth login"
  fi
fi

# --advisor (slot launch flag) needs Claude Code >= 2.1.98
if command -v claude >/dev/null 2>&1; then
  CC_VER=$(claude --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
  if [ -n "$CC_VER" ] && [ "$(printf '%s\n' "2.1.98" "$CC_VER" | sort -V | head -1)" = "2.1.98" ]; then
    ok "claude $CC_VER (>= 2.1.98, --advisor supported)"
  else
    bad "claude ${CC_VER:-version unknown} < 2.1.98 — slot launch uses --advisor; update Claude Code"
  fi
fi

echo
echo "── Claude Code plugins (enabledPlugins) ─────────"
if [ -f "$SETTINGS" ] && command -v python3 >/dev/null 2>&1; then
  for plugin in context7@claude-plugins-official figma@claude-plugins-official \
                superpowers@claude-plugins-official typescript-lsp@claude-plugins-official \
                swift-lsp@claude-plugins-official; do
    state=$(python3 -c "
import json,sys
try:
    d = json.load(open('$SETTINGS'))
    print(d.get('enabledPlugins', {}).get('$plugin', False))
except Exception:
    print('parse-error')
")
    case "$state" in
      True)  ok "$plugin" ;;
      parse-error) bad "could not parse $SETTINGS" ; break ;;
      *)     bad "$plugin not enabled — run /plugin in Claude Code (interactive; not auto-installed)" ;;
    esac
  done
else
  bad "$SETTINGS missing or python3 unavailable"
fi
warn "Figma MCP OAuth cannot be checked from the shell — verify in a Claude session: ask it to call mcp__figma__whoami (re-auth via /mcp if it fails)"

echo
echo "── Settings policy ──────────────────────────────"
# Sentinel checks over the MERGED view (settings.json + settings.local.json —
# rules may legitimately live in either).
if command -v python3 >/dev/null 2>&1; then
  POLICY=$(python3 - <<'PYEOF'
import json, os
home = os.path.expanduser('~')
merged = {'allow': set(), 'deny': set()}
scalars = {}
mkts = {}
for name in ('settings.json', 'settings.local.json'):
    path = f'{home}/.claude/{name}'
    if not os.path.exists(path):
        continue
    try:
        d = json.load(open(path))
    except Exception:
        print(f'PARSE_ERROR {name}')
        continue
    for kind in ('allow', 'deny'):
        merged[kind] |= set(d.get('permissions', {}).get(kind, []))
    for k in ('skipAutoPermissionPrompt', 'autoCompactEnabled', 'includeCoAuthoredBy'):
        if k in d:
            scalars.setdefault(k, d[k])
    mkts.update(d.get('extraKnownMarketplaces', {}))

def flag(cond, name): print(('OK ' if cond else 'NG ') + name)
flag('Bash(cteam-send *)' in merged['allow'], 'allow:cteam-bins')
flag('Write(~/.claude/**)' in merged['deny'], 'deny:claude-config')
flag('Bash(git reset --hard *)' in merged['deny'], 'deny:git-hard-reset')
flag(scalars.get('skipAutoPermissionPrompt') is True, 'skipAutoPermissionPrompt')
flag(scalars.get('autoCompactEnabled') is True, 'warn:autoCompactEnabled')
flag(scalars.get('includeCoAuthoredBy') is False, 'warn:includeCoAuthoredBy')
flag('obsidian-skills' in mkts, 'warn:marketplace-obsidian')
stale = [r for r in merged['allow'] | merged['deny'] if 'claude_ai_Figma' in r]
flag(not stale, 'warn:stale-figma-rules')
PYEOF
)
  while IFS= read -r line; do
    name="${line#* }"
    case "$line" in
      OK\ warn:*) ok "${name#warn:}" ;;
      NG\ warn:autoCompactEnabled)   warn "autoCompactEnabled not true — long PM sessions will hit hard context limits" ;;
      NG\ warn:includeCoAuthoredBy)  warn "includeCoAuthoredBy not false — commits will carry Claude attribution (docs say disabled)" ;;
      NG\ warn:marketplace-obsidian) warn "obsidian-skills marketplace not registered — obsidian skills can't be (re)installed" ;;
      NG\ warn:stale-figma-rules)    warn "stale mcp__claude_ai_Figma__* rules present — server renamed to figma; clean them" ;;
      OK\ allow:cteam-bins)          ok "permissions: cteam bin allows" ;;
      NG\ allow:cteam-bins)          bad "permissions: cteam bin allows missing — re-run install.sh (panes will prompt on every cteam-send)" ;;
      OK\ deny:claude-config)        ok "permissions: ~/.claude write-deny" ;;
      NG\ deny:claude-config)        bad "permissions: Write(~/.claude/**) deny missing — re-run install.sh" ;;
      OK\ deny:git-hard-reset)       ok "permissions: git reset --hard deny" ;;
      NG\ deny:git-hard-reset)       bad "permissions: Bash(git reset --hard *) deny missing — re-run install.sh" ;;
      OK\ skipAutoPermissionPrompt)  ok "skipAutoPermissionPrompt: true" ;;
      NG\ skipAutoPermissionPrompt)  bad "skipAutoPermissionPrompt not true — every pane stalls on the auto-mode prompt; re-run install.sh" ;;
      PARSE_ERROR*)                  bad "cannot parse ${line#PARSE_ERROR }" ;;
    esac
  done <<< "$POLICY"
else
  warn "python3 unavailable — settings policy checks skipped"
fi

# Per-project Claude settings are against the centralize-at-user-level policy
PJ_SETTINGS=$(find "$HOME/work" -maxdepth 3 -path "*/.claude/settings*.json" 2>/dev/null | grep -v "^$HOME/work/cteam/" || true)
if [ -n "$PJ_SETTINGS" ]; then
  warn "per-project Claude settings found (policy: centralize at user level — absorb useful rules, then delete):"
  echo "$PJ_SETTINGS" | sed 's/^/     /'
else
  ok "no per-project Claude settings under ~/work"
fi

echo
echo "── cteam wiring ─────────────────────────────────"
SKILLS="andon bug-spike cteam-code-review create-issue pre-pr typescript-safety ui-implement figma-preflight figma-create figma-review fable-style"
missing=0
for s in $SKILLS; do
  if [ -e "$HOME/.claude/skills/$s/SKILL.md" ]; then :; else missing=$((missing+1)); bad "skill not installed: $s"; fi
done
[ "$missing" -eq 0 ] && ok "11 cteam skills present in ~/.claude/skills/"

for a in code-reviewer typescript-reviewer security-reviewer; do
  if [ -e "$HOME/.claude/agents/$a.md" ]; then
    ok "agent: $a"
  else
    bad "agent missing: ~/.claude/agents/$a.md"
  fi
done

for r in shared pm slot design; do
  [ -f "$CTEAM_HOME/roles/$r.md" ] && ok "roles/$r.md" || bad "roles/$r.md missing from repo"
done

if grep -q "roles/shared.md" "$HOME/.claude/CLAUDE.md" 2>/dev/null; then
  if grep -q "config/tmux/cteam" "$HOME/.claude/CLAUDE.md" 2>/dev/null; then
    bad "~/.claude/CLAUDE.md still points at the legacy ~/.config/tmux/cteam path — re-run install.sh"
  else
    ok "~/.claude/CLAUDE.md cteam pointer"
  fi
else
  bad "~/.claude/CLAUDE.md has no cteam pointer — re-run install.sh"
fi

if command -v cteam-send >/dev/null 2>&1 && [ "$(command -v cteam-send)" = "$CTEAM_HOME/bin/cteam-send" ]; then
  ok "bin on PATH ($CTEAM_HOME/bin)"
else
  warn "cteam bin not first on PATH in this shell (panes get it injected; for your shell, source ~/.zshrc)"
fi

if grep -q "cteam_cron" "$HOME/.config/tmux/tmux.conf" 2>/dev/null \
   || grep -q "cteam_cron" "$HOME/.tmux.conf" 2>/dev/null; then
  ok "tmux session-closed cron-kill hook"
else
  warn "tmux conf lacks the session-closed cron-kill hook — re-run install.sh (cteam-end still kills cron; this is the safety net)"
fi

echo
echo "── Vault / Obsidian workflow ────────────────────"
[ -d "$HOME/vault" ]      && ok "~/vault"      || bad "~/vault missing"
[ -d "$HOME/vault/Work" ] && ok "~/vault/Work" || warn "~/vault/Work missing (created per-project by cteam / cteam-init)"

# Wired by install.sh (required — protocol references /save, /organize, vault rules)
if [ -e "$HOME/.claude/rules/cteam/obsidian/vault.md" ]; then
  ok "vault rules (~/.claude/rules/cteam/obsidian/vault.md)"
else
  bad "vault rules not installed — re-run install.sh"
fi
for c in save organize; do
  if [ -e "$HOME/.claude/commands/$c.md" ]; then
    ok "/$c command"
  else
    bad "/$c command missing — re-run install.sh"
  fi
done

# Optional: Obsidian app/CLI + skills (vault writes are plain files and work without these)
command -v obsidian >/dev/null 2>&1 \
  && ok "obsidian CLI" \
  || warn "obsidian CLI not found — obsidian-cli skill unusable (vault file writes still work)"
[ -d "/Applications/Obsidian.app" ] \
  && ok "Obsidian.app" \
  || warn "Obsidian.app not installed — brew install --cask obsidian"
for s in obsidian-cli obsidian-markdown obsidian-bases; do
  if [ -e "$HOME/.claude/skills/$s/SKILL.md" ]; then
    ok "skill: $s"
  else
    warn "skill $s missing — install from the kepano/obsidian-skills marketplace (/plugin)"
  fi
done

echo
echo "── Optional ─────────────────────────────────────"
if [ -f "$HOME/.claude/scripts/hooks/run-with-flags.js" ]; then
  ok "lint-hook lib (~/.claude/scripts) present — stop:format-typecheck hooks functional"
else
  warn "lint-hook lib (~/.claude/scripts) absent — the two lint hooks in settings-fragment.json will be skipped by install.sh"
fi

if [ -n "$TARGET_REPO" ] || git -C . rev-parse --git-dir >/dev/null 2>&1; then
  REPO_ARGS=()
  [ -n "$TARGET_REPO" ] && REPO_ARGS=(--repo "$TARGET_REPO")
  if labels=$(gh label list "${REPO_ARGS[@]}" --limit 200 --json name --jq '.[].name' 2>/dev/null); then
    need=0
    for l in priority:high domain:ui type:bug status:todo size:m; do
      echo "$labels" | grep -qx "$l" || need=$((need+1))
    done
    if [ "$need" -eq 0 ]; then
      ok "label scheme present (${TARGET_REPO:-current repo})"
    else
      warn "label scheme incomplete (${TARGET_REPO:-current repo}) — run: cteam-init <project> to create it"
    fi
  else
    warn "could not list labels (no repo context or no access) — pass owner/repo: cteam-doctor owner/repo"
  fi
else
  warn "not in a git repo and no owner/repo argument — label check skipped"
fi

echo
if [ "$FAIL" -eq 0 ]; then
  echo "All required checks passed."
else
  echo "Some required checks FAILED — see ✗ above."
fi
exit "$FAIL"
